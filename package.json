{
  "name": "@kindflow/zoom-mcp-server",
  "version": "1.0.6",
  "description": "MCP server for Zoom API — meetings, transcripts, users, and team chat",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "zoom-mcp-server": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "zoom",
    "mcp",
    "model-context-protocol",
    "claude",
    "meetings",
    "transcripts"
  ],
  "author": "surajpratap",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/surajpratap/zoom-mcp-server.git"
  },
  "homepage": "https://github.com/surajpratap/zoom-mcp-server#readme",
  "bugs": {
    "url": "https://github.com/surajpratap/zoom-mcp-server/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
